# ========================================
# 🚀 PIXEL RISE - GITIGNORE OPTIMISÉ DÉPLOIEMENT
# Fichiers exclus: développement local uniquement
# ========================================

# ========================================
# 📦 NODE.JS / REACT / VITE
# ========================================

# Dépendances
react-frontend/node_modules/
node_modules/

# Cache et build
react-frontend/.vite/
react-frontend/dist/
react-frontend/build/
react-frontend/.cache/
react-frontend/.turbo/

# ⚠️ FICHIERS ENVIRONNEMENT SERVEUR (ignorés pour éviter écrasement)
react-frontend/.env
react-frontend/vite.config.ts

# ✅ AUTORISÉ : Fichiers .production (templates pour serveurs)
!react-frontend/.env.production
!react-frontend/vite.config.production.ts

# Fichiers locaux uniquement
react-frontend/.env.local
react-frontend/.env.development
react-frontend/.env.staging

# Package Microsoft
packages.microsoft.gpg

# Environnement local
react-frontend/.env.local
react-frontend/.env.development.local
react-frontend/.env.test.local
react-frontend/.env.production.local

# Fichiers systèmes
react-frontend/.DS_Store
react-frontend/Thumbs.db

# ========================================
# 🐘 LARAVEL / PHP
# ========================================

# Dépendances Composer
laravel-backend/vendor/

# Environnement et configuration actifs (propres à chaque serveur)
laravel-backend/.env
laravel-backend/.env.dev
.env
.env.dev

# ✅ AUTORISÉ : Fichiers .env TEMPLATES (à copier sur chaque serveur)
!.env.production
!.env.staging
!.env.local.example
!laravel-backend/.env.production
!laravel-backend/.env.staging
!laravel-backend/.env.local.example

# Storage et cache
laravel-backend/storage/*.key
laravel-backend/storage/app/public
laravel-backend/storage/debugbar
laravel-backend/storage/framework/*
!laravel-backend/storage/framework/.gitignore
laravel-backend/storage/logs/*
!laravel-backend/storage/logs/.gitignore
laravel-backend/public/storage
laravel-backend/bootstrap/cache/*
!laravel-backend/bootstrap/cache/.gitignore

# Fichiers temporaires Laravel
laravel-backend/,
laravel-backend/-
laravel-backend/*,
laravel-backend/*.tmp
laravel-backend/temp_*

# Base de données locale
laravel-backend/database/database.sqlite
laravel-backend/database/backups/*.sql

